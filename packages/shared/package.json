{
  "name": "@sentinelai/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types, utilities, and constants for SentinelAI",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./constants": "./src/constants/index.ts",
    "./utils": "./src/utils/index.ts",
    "./validators": "./src/validators/index.ts",
    "./errors": "./src/errors/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "eslint": "^9.8.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.4"
  }
}
