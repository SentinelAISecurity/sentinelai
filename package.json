{
  "name": "sentinelai",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Powered Web3 Security Platform",
  "license": "Apache-2.0",
  "author": "SentinelAI Contributors",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,py,rs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,py,rs}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky install",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "docs:dev": "turbo run dev --filter=docs",
    "docs:build": "turbo run build --filter=docs",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up --build"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.6.0",
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "husky": "^9.1.4",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "turbo": "^2.0.9",
    "typescript": "^5.5.4"
  }
}
