{
  "name": "@sentinelai/ai-engine",
  "version": "1.0.0",
  "private": true,
  "description": "AI engine for vulnerability explanation, fix suggestion, and report generation",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
