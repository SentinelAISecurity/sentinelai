{
  "name": "@sentinelai/report-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Audit report generation in Markdown, JSON, PDF, and HTML formats",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sentinelai/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "eslint": "^9.8.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.4"
  }
}
