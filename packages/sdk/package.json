{
  "name": "@sentinelai/sdk",
  "version": "1.0.0",
  "private": true,
  "description": "SentinelAI SDK - JavaScript client for the SentinelAI API",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sentinelai/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "eslint": "^9.8.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.4"
  }
}
